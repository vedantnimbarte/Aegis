# ---- Core ----
PROJECT_NAME=Aegis
ENVIRONMENT=development
DEBUG=true

# ---- Database ----
DATABASE_URL=postgresql+psycopg://aegis:aegis@localhost:5432/aegis

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=        # defaults to REDIS_URL
# CELERY_RESULT_BACKEND=    # defaults to REDIS_URL

# ---- Auth / JWT ----
# Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Encryption (AES-256-GCM for github_token at rest) ----
# Generate: python -c "import os,base64;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=change-me-url-safe-base64-of-32-bytes

# ---- GitHub OAuth ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs for the self-serve tiers (from the Stripe dashboard).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Where Checkout / the billing portal return the user (the dashboard app).
DASHBOARD_URL=http://localhost:3001

# ---- LLM providers (forwarded to Strix) ----
# Model id in LiteLLM provider/model form, e.g. openai/gpt-4o or
# anthropic/claude-sonnet-4-6.
STRIX_LLM=openai/gpt-4o
# Strix authenticates with a single LLM_API_KEY. If blank, Aegis falls back to
# the provider key below that matches STRIX_LLM's prefix.
LLM_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional: enables Strix's web-search capability.
PERPLEXITY_API_KEY=

# ---- Strix engine ----
# CLI executable (from the strix-agent package) and per-scan working dir.
STRIX_BIN=strix
STRIX_WORK_DIR=/tmp/aegis-scans
# Hard cap on a single scan's wall-clock (seconds); keep below Celery's limit.
STRIX_SCAN_TIMEOUT_SECONDS=3600
# Optional guardrails (leave blank to disable).
# STRIX_MAX_BUDGET_USD=5
# STRIX_REASONING_EFFORT=medium
GIT_CLONE_TIMEOUT_SECONDS=300

# ---- CORS (comma-separated) ----
BACKEND_CORS_ORIGINS=http://localhost:3000
