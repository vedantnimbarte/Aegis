# Base URL of the Aegis FastAPI backend (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# GitHub OAuth app credentials (the client ID is public/safe to expose).
# The redirect URI MUST match both your GitHub OAuth app config and the
# backend's GITHUB_OAUTH_REDIRECT_URI.
NEXT_PUBLIC_GITHUB_CLIENT_ID=
NEXT_PUBLIC_GITHUB_REDIRECT_URI=http://localhost:3001/auth/callback
